{
  "name": "braille-frontend",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "teste_automatizado:adm": "cypress run --env role=admin",
    "teste_automatizado:secretaria": "cypress run --env role=secretaria",
    "teste_automatizado:professor": "cypress run --env role=professor",
    "teste_automatizado:comunicacao": "cypress run --env role=comunicacao",
    "teste_automatizado:gui": "cypress open"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "overrides": {
    "lodash-es": "4.18.1"
  },
  "dependencies": {
    "@angular/animations": "^21.1.0",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@angular/service-worker": "^21.1.0",
    "@sentry/angular": "^10.42.0",
    "dompurify": "^3.3.3",
    "ngx-quill": "^30.0.1",
    "pdfjs-dist": "^5.5.207",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.0",
    "@types/dompurify": "^3.0.5",
    "@types/pdfjs-dist": "^2.10.377",
    "@types/quill": "^2.0.14",
    "angular-eslint": "21.0.0",
    "autoprefixer": "^10.4.24",
    "axe-core": "^4.11.1",
    "cypress": "^15.11.0",
    "cypress-axe": "^1.7.0",
    "eslint": "^9.39.1",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.46.4",
    "vitest": "^4.0.8"
  }
}
